manifest {
    name        = 'nf-pore2taxa'
    version     = '1.0.0a'
    description = 'Nanopore metabarcoding (quick) taxonomic assignment workflow'
    author      = 'Frédéric Mahé'
    homePage    = 'https://github.com/frederic-mahe/nf-pore2taxa'
    mainScript  = 'main.nf'
}

params {
    // Paths — no defaults, must be supplied via project config or CLI
    pod5_dir      = null
    fastq_dir     = null
    sintax_silva  = null
    results_table = null
    primer_f      = null
    primer_r      = null

    // Workflow behaviour
    skip_basecall = false
    version       = '1.0.0a'
}

profiles {
    standard {
        process.executor = 'local'
    }
    cluster {
        process.executor  = 'slurm'
        process.queue     = 'normal'
    }
}

// Default resource hints — override per-process in modules if needed
process {
    cpus   = 4
    memory = '16 GB'
    time   = '4 h'

    withName: 'BASECALL' {
        cpus   = 8
        memory = '32 GB'
        time   = '12 h'
    }
    withName: 'SINTAX' {
        cpus   = 4
        memory = '16 GB'
    }
    withName: 'BUILD_TABLE' {
        cpus   = 1
        memory = '8 GB'
    }
}
