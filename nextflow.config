manifest {
    name        = 'nf-pore2taxa'
    version     = '1.3.0'
    description = 'Nanopore metabarcoding (quick) taxonomic assignment workflow'
    author      = 'Frédéric Mahé'
    homePage    = 'https://github.com/frederic-mahe/nf-pore2taxa'
    mainScript  = 'main.nf'
}

cleanup = true

params {
    // Paths — no defaults, must be supplied via project config or CLI
    pod5_dir          = null
    fastq_dir         = null
    sintax_references = null
    sintax_silva      = null  // deprecated alias for sintax_references
    results_table     = null
    primer_f          = null
    primer_r          = null

    // Workflow behaviour
    skip_basecall     = false

    // Primer-presence filtering. true (default): drop reads in which a
    // primer is not found (strict amplicon filtering). false: keep every
    // read, trimming primers only where they are found.
    discard_untrimmed = true

    // publishDir mode for every published output. 'link' (fast hard
    // link) is correct when workDir and the data/results directories
    // share a filesystem; set 'copy' when they are on different
    // filesystems (hard links cannot cross devices). See the README
    // same-filesystem warning. Validated at workflow startup.
    publish_mode      = 'link'

    version           = '1.3.0'
}

profiles {
    standard {
        process.executor = 'local'
    }
    cluster {
        process.executor  = 'slurm'
        process.queue     = 'normal'
    }
    // Resolve cutadapt/vsearch/python from the pinned environment.yml
    // instead of the bare PATH. Compose with any executor profile, e.g.
    // `-profile standard,conda`. Nextflow builds the env once and caches
    // it under $NXF_CONDA_CACHEDIR.
    //
    // dorado is not on bioconda (see environment.yml), so the conda
    // directive is scoped to the tool steps that CAN be packaged; the
    // BASECALL process stays bare-PATH and still needs dorado + pigz
    // installed where it runs.
    conda {
        conda.enabled = true
        process {
            withName: 'SINTAX'      { conda = "${projectDir}/environment.yml" }
            withName: 'BUILD_TABLE' { conda = "${projectDir}/environment.yml" }
        }
    }
}

// Default resource hints — override per-process in modules if needed
process {
    cpus   = 4
    memory = '16 GB'
    // time   = '4 h'

    withName: 'BASECALL' {
        cpus   = 8
        memory = '32 GB'
        // time   = '12 h'
    }
    withName: 'SINTAX' {
        cpus   = 20
        memory = '16 GB'
    }
    withName: 'BUILD_TABLE' {
        cpus   = 1
        memory = '8 GB'
    }
}
