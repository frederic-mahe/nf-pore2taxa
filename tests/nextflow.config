// Test-only Nextflow config.
//
// nf-test merges this file with the project's nextflow.config. Keep
// it minimal: only set what differs between production runs and
// tests. Per-test parameter overrides belong inside each .nf.test
// file's `params { ... }` block.

cleanup = false  // keep work dirs around so tests can inspect intermediates

params {
    // Sensible defaults for fixture-driven tests. Individual tests
    // can override any of these.
    primer_f      = "GTACACACCGCCCGTCG"
    primer_r      = "CGCCTSCSCTTANTDATATGC"
    skip_basecall = true
}

process {
    // Tests run on a developer laptop or CI runner — keep resource
    // requests modest so they don't fail to schedule.
    cpus   = 1
    memory = '2 GB'

    withName: 'BASECALL'    { cpus = 1; memory = '2 GB' }
    withName: 'SINTAX'      { cpus = 2; memory = '2 GB' }
    withName: 'BUILD_TABLE' { cpus = 1; memory = '2 GB' }
}
