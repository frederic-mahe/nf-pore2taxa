// Pipeline-level test, with skip_basecall=true.
//
// Drives the full workflow (SINTAX + BUILD_TABLE) against the
// committed fixture. Asserts structural invariants on the published
// TSV files, not exact taxonomic content.
//
// NOTE: BUILD_TABLE shells out to `python3` (standard library only),
// so no extra runtime dependency is required beyond a Python 3
// interpreter, which is virtually always present.
//
// Hermeticity: the pipeline publishes to params.fastq_dir. Pointing
// that at the committed fixture would pollute the source tree, so we
// copy the fixture into outputDir/fastq_dir on each run.

nextflow_pipeline {

    name "Workflow (skip_basecall=true)"
    script "main.nf"

    test("happy path: produces filtered + optimistic TSV with expected structure") {

        setup {
            // Copy the read-only fixture into a per-test scratch
            // location that the pipeline can publish into.
            new File("${outputDir}/fastq_dir").mkdirs()
            ["cp", "-r",
             "${projectDir}/tests/fixtures/fastq_dir/fastq_pass",
             "${outputDir}/fastq_dir/"].execute().waitFor()
        }

        when {
            params {
                skip_basecall     = true
                fastq_dir         = "${outputDir}/fastq_dir"
                sintax_references = "${projectDir}/tests/fixtures/references.fasta"
                results_table     = "${outputDir}/sintax.tsv"
                primer_f          = "GTACACACCGCCCGTCG"
                primer_r          = "CGCCTSCSCTTANTDATATGC"
            }
        }

        then {
            assert workflow.success

            // WF-06: exactly two TSV files are produced: the
            // filtered table and its '_optimistic' sibling.
            def filtered   = file("${outputDir}/sintax.tsv")
            def optimistic = file("${outputDir}/sintax_optimistic.tsv")
            assert filtered.exists()
            assert optimistic.exists()

            // BT-10: header line shape.
            def header = filtered.readLines()[0].split("\t", -1)
            assert header[0] == "taxonomy"
            assert header[1] == "total"
            // Remaining columns are barcode names from the fixture.
            assert (header.drop(2) as Set) == (["barcode01", "barcode02", "barcode03"] as Set)

            // BT-13: empty barcode (barcode03) is the right-most column.
            assert header[-1] == "barcode03"

            // BT-11: 'total' equals the row-wise sum of barcode columns.
            filtered.readLines().drop(1).each { row ->
                def cols = row.split("\t", -1)
                def total       = cols[1].toInteger()
                def barcode_sum = cols.drop(2).collect { it.toInteger() }.sum()
                assert total == barcode_sum : "row '${cols[0]}': total=${total} != sum=${barcode_sum}"
            }

            // The fixture is deterministic: 5 reads per non-empty
            // barcode survive primer trimming and are confidently
            // assigned to distinct taxa.
            assert filtered.readLines().size() >= 2 + 1  // header + at least 2 taxa rows

            // BT-20: optimistic table has the same header shape.
            def opt_header = optimistic.readLines()[0].split("\t", -1)
            assert opt_header[0] == "taxonomy"
            assert opt_header[1] == "total"
            assert (opt_header.drop(2) as Set) == (header.drop(2) as Set)

            // BT-22: keeping low-confidence assignments cannot lose
            // reads. The grand total in the optimistic table must be
            // >= the grand total in the filtered table.
            def grand_total = { f ->
                f.readLines().drop(1).collect { it.split("\t", -1)[1].toInteger() }.sum()
            }
            assert grand_total(optimistic) >= grand_total(filtered)

            // BT-23: no probability annotations leak into the
            // taxonomy column (e.g. 'd:Fungi(0.99)' should never
            // appear).
            [filtered, optimistic].each { f ->
                f.readLines().drop(1).each { row ->
                    def tax = row.split("\t", -1)[0]
                    assert !(tax =~ /\([0-9]+\.[0-9]+\)/) : "probability leaked in ${f.name}: '${tax}'"
                }
            }
        }
    }

    test("aborts when sintax_references references file is missing") {

        when {
            params {
                skip_basecall     = true
                fastq_dir         = "${projectDir}/tests/fixtures/fastq_dir"
                sintax_references = "${projectDir}/tests/fixtures/__does_not_exist__.fasta"
                results_table     = "${outputDir}/sintax.tsv"
                primer_f          = "GTACACACCGCCCGTCG"
                primer_r          = "CGCCTSCSCTTANTDATATGC"
            }
        }

        then {
            // WF-03: pipeline must abort before any process runs.
            assert workflow.failed
        }
    }

    test("aborts when fastq_dir is missing and skip_basecall=true") {

        when {
            params {
                skip_basecall     = true
                fastq_dir         = "${projectDir}/tests/fixtures/__no_such_dir__"
                sintax_references = "${projectDir}/tests/fixtures/references.fasta"
                results_table     = "${outputDir}/sintax.tsv"
                primer_f          = "GTACACACCGCCCGTCG"
                primer_r          = "CGCCTSCSCTTANTDATATGC"
            }
        }

        then {
            // WF-04
            assert workflow.failed
        }
    }

    test("WF-08 deprecated sintax_silva alias drives the workflow") {

        setup {
            new File("${outputDir}/fastq_dir").mkdirs()
            ["cp", "-r",
             "${projectDir}/tests/fixtures/fastq_dir/fastq_pass",
             "${outputDir}/fastq_dir/"].execute().waitFor()
        }

        when {
            params {
                skip_basecall     = true
                fastq_dir         = "${outputDir}/fastq_dir"
                // No sintax_references: the deprecated alias must be used.
                sintax_silva      = "${projectDir}/tests/fixtures/references.fasta"
                results_table     = "${outputDir}/sintax.tsv"
                primer_f          = "GTACACACCGCCCGTCG"
                primer_r          = "CGCCTSCSCTTANTDATATGC"
            }
        }

        then {
            // WF-08: sintax_silva is honoured as an alias for
            // sintax_references and the pipeline runs to completion.
            // (The accompanying deprecation warning, emitted via
            // log.warn, is asserted in tests/config/deprecation.bats —
            // nf-test does not capture the Nextflow log stream.)
            assert workflow.success
            assert file("${outputDir}/sintax.tsv").exists()
        }
    }

    test("WF-09 sintax_references takes precedence over sintax_silva") {

        setup {
            new File("${outputDir}/fastq_dir").mkdirs()
            ["cp", "-r",
             "${projectDir}/tests/fixtures/fastq_dir/fastq_pass",
             "${outputDir}/fastq_dir/"].execute().waitFor()
        }

        when {
            params {
                skip_basecall     = true
                fastq_dir         = "${outputDir}/fastq_dir"
                // sintax_references is valid; sintax_silva points at a
                // non-existent file. If the alias wrongly won, the
                // pipeline would abort on the missing path.
                sintax_references = "${projectDir}/tests/fixtures/references.fasta"
                sintax_silva      = "${projectDir}/tests/fixtures/__does_not_exist__.fasta"
                results_table     = "${outputDir}/sintax.tsv"
                primer_f          = "GTACACACCGCCCGTCG"
                primer_r          = "CGCCTSCSCTTANTDATATGC"
            }
        }

        then {
            // WF-09: canonical param wins; the bad alias is ignored.
            assert workflow.success
            assert file("${outputDir}/sintax.tsv").exists()
        }
    }

    test("WF-10 aborts when sintax_silva alias points at a missing file") {

        when {
            params {
                skip_basecall     = true
                fastq_dir         = "${projectDir}/tests/fixtures/fastq_dir"
                // Only the deprecated alias is set, and it is invalid:
                // the alias must still flow through checkIfExists.
                sintax_silva      = "${projectDir}/tests/fixtures/__does_not_exist__.fasta"
                results_table     = "${outputDir}/sintax.tsv"
                primer_f          = "GTACACACCGCCCGTCG"
                primer_r          = "CGCCTSCSCTTANTDATATGC"
            }
        }

        then {
            // WF-10: the alias is consumed by Channel.fromPath with
            // checkIfExists, so a bad path aborts before any process runs.
            assert workflow.failed
        }
    }

    test("WF-11 startup validation aborts on a missing required parameter") {

        when {
            params {
                skip_basecall     = true
                fastq_dir         = "${projectDir}/tests/fixtures/fastq_dir"
                sintax_references = "${projectDir}/tests/fixtures/references.fasta"
                // results_table deliberately omitted (null).
                primer_f          = "GTACACACCGCCCGTCG"
                primer_r          = "CGCCTSCSCTTANTDATATGC"
            }
        }

        then {
            // WF-11: aborts at startup with the aggregated report, before
            // any process runs and before the deeper file()/tool errors.
            assert workflow.failed
            assert workflow.stdout.any { it.contains("Parameter validation failed") }
            assert workflow.stdout.any { it.contains("results_table") }
        }
    }

    test("SX-41 flat layout (barcode in filename), multi-file barcode, fastq_fail ignored") {

        setup {
            new File("${outputDir}/flat_dir").mkdirs()
            ["cp", "-r",
             "${projectDir}/tests/fixtures/flat_dir/fastq_pass",
             "${projectDir}/tests/fixtures/flat_dir/fastq_fail",
             "${outputDir}/flat_dir/"].execute().waitFor()
        }

        when {
            params {
                skip_basecall     = true
                fastq_dir         = "${outputDir}/flat_dir"
                sintax_references = "${projectDir}/tests/fixtures/references.fasta"
                results_table     = "${outputDir}/flat.tsv"
                primer_f          = "GTACACACCGCCCGTCG"
                primer_r          = "CGCCTSCSCTTANTDATATGC"
            }
        }

        then {
            assert workflow.success
            def filtered = file("${outputDir}/flat.tsv")
            assert filtered.exists()

            def header = filtered.readLines()[0].split("\t", -1)
            // barcode token comes from the filename; fastq_fail is excluded.
            assert (header.drop(2) as Set) == (["barcode01", "barcode02"] as Set)

            // barcode01 is split across two fastq files → 5 reads total
            // (NOT 10: the 5 fastq_fail reads must not be counted).
            def b01col = header.findIndexOf { it == "barcode01" }
            def b01total = filtered.readLines().drop(1)
                .collect { it.split("\t", -1)[b01col].toInteger() }.sum()
            assert b01total == 5 : "barcode01 should total 5 reads, got ${b01total}"
        }
    }

    test("WF-11 startup validation aborts on an invalid publish_mode") {

        when {
            params {
                skip_basecall     = true
                fastq_dir         = "${projectDir}/tests/fixtures/fastq_dir"
                sintax_references = "${projectDir}/tests/fixtures/references.fasta"
                results_table     = "${outputDir}/sintax.tsv"
                primer_f          = "GTACACACCGCCCGTCG"
                primer_r          = "CGCCTSCSCTTANTDATATGC"
                publish_mode      = "hardlink"  // not a valid publishDir mode
            }
        }

        then {
            assert workflow.failed
            assert workflow.stdout.any { it.contains("publish_mode") }
        }
    }
}
